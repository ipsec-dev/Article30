{
  "name": "article30",
  "private": true,
  "license": "AGPL-3.0-only",
  "version": "1.1.5",
  "scripts": {
    "dev": "pnpm --filter @article30/shared build && pnpm --parallel --filter backend --filter frontend dev",
    "dev:prod": "pnpm build && NODE_ENV=production pnpm --parallel --filter backend --filter frontend start",
    "build": "pnpm --filter shared build && pnpm --parallel --filter backend --filter frontend build",
    "lint": "pnpm -r lint",
    "generate:api": "pnpm --filter frontend generate:api",
    "seed": "pnpm --filter backend seed",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:studio": "pnpm --filter backend db:studio",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "pnpm --filter @article30/shared build && pnpm -r --parallel exec tsc --noEmit",
    "test": "pnpm --filter @article30/shared build && pnpm --filter @article30/backend test",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "vite": "^8.1.4"
  },
  "lint-staged": {
    "backend/src/**/*.ts": "backend/node_modules/.bin/eslint --config backend/eslint.config.mjs --fix",
    "frontend/src/**/*.{ts,tsx}": "frontend/node_modules/.bin/eslint --config frontend/eslint.config.mjs --fix",
    "shared/src/**/*.ts": "shared/node_modules/.bin/eslint --config shared/eslint.config.mjs --fix",
    "**/*.{ts,tsx,js,mjs,json,md,css,yml,yaml}": "prettier --write"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "@nestjs/core"
    ],
    "overrides": {
      "ajv@8.17.1": "8.18.0",
      "effect@3.18.4": "3.20.0",
      "picomatch@4.0.2": "4.0.4",
      "serialize-javascript@6.0.2": "7.0.5",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "hono@<4.12.25": ">=4.12.25",
      "multer@<2.2.0": ">=2.2.0",
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "fast-uri@<3.1.1": ">=3.1.1"
    }
  }
}
