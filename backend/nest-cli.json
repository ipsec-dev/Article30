{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "modules/mail/templates/*.txt",
        "outDir": "dist/src"
      },
      {
        "include": "common/pdf/fonts/*.{ttf,txt}",
        "outDir": "dist/src"
      }
    ]
  }
}
